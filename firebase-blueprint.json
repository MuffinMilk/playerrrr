{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and current playing status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "friendCode": { "type": "string" },
        "typingTo": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "number" },
        "currentSong": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "artist": { "type": "string" },
            "coverUrl": { "type": "string" }
          }
        }
      },
      "required": ["uid", "friendCode"]
    },
    "FriendRequest": {
      "title": "FriendRequest",
      "description": "A request to become friends",
      "type": "object",
      "properties": {
        "fromUid": { "type": "string" },
        "fromName": { "type": "string" },
        "fromPhoto": { "type": "string" },
        "toUid": { "type": "string" },
        "status": { "type": "string", "enum": ["pending"] },
        "createdAt": { "type": "number" }
      },
      "required": ["fromUid", "toUid", "status", "createdAt"]
    },
    "Friendship": {
      "title": "Friendship",
      "description": "A friendship between two users",
      "type": "object",
      "properties": {
        "user1": { "type": "string" },
        "user2": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["user1", "user2", "createdAt"]
    },
    "Playlist": {
      "title": "Playlist",
      "description": "A user's playlist",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "songs": { "type": "array" },
        "isFavorites": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "name", "songs", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message between friends",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["senderId", "receiverId", "text", "createdAt"]
    },
    "Call": {
      "title": "Call",
      "description": "A voice/video call between friends",
      "type": "object",
      "properties": {
        "callerId": { "type": "string" },
        "receiverId": { "type": "string" },
        "offer": { "type": "object" },
        "answer": { "type": "object" },
        "status": { "type": "string", "enum": ["ringing", "ongoing", "ended"] },
        "type": { "type": "string", "enum": ["voice", "video"] },
        "createdAt": { "type": "number" }
      },
      "required": ["callerId", "receiverId", "status", "type", "createdAt"]
    },
    "CallCandidate": {
      "title": "CallCandidate",
      "description": "An ICE candidate for WebRTC",
      "type": "object",
      "properties": {
        "callId": { "type": "string" },
        "senderId": { "type": "string" },
        "candidate": { "type": "object" },
        "createdAt": { "type": "number" }
      },
      "required": ["callId", "senderId", "candidate", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/friendRequests/{requestId}": {
      "schema": { "$ref": "#/entities/FriendRequest" },
      "description": "Pending friend requests"
    },
    "/friendships/{friendshipId}": {
      "schema": { "$ref": "#/entities/Friendship" },
      "description": "Established friendships"
    },
    "/playlists/{playlistId}": {
      "schema": { "$ref": "#/entities/Playlist" },
      "description": "User playlists"
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Chat messages"
    },
    "/calls/{callId}": {
      "schema": { "$ref": "#/entities/Call" },
      "description": "Active or past calls"
    },
    "/calls/{callId}/candidates/{candidateId}": {
      "schema": { "$ref": "#/entities/CallCandidate" },
      "description": "ICE candidates for a call"
    },
    "/groups/{groupId}": {
      "schema": {
        "title": "Group",
        "description": "A group chat",
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "ownerId": { "type": "string" },
          "members": { "type": "array", "items": { "type": "string" } },
          "createdAt": { "type": "number" }
        },
        "required": ["name", "ownerId", "members", "createdAt"]
      },
      "description": "Group chats"
    },
    "/groupMessages/{messageId}": {
      "schema": {
        "title": "GroupMessage",
        "description": "A message in a group chat",
        "type": "object",
        "properties": {
          "groupId": { "type": "string" },
          "senderId": { "type": "string" },
          "senderName": { "type": "string" },
          "senderPhoto": { "type": "string" },
          "text": { "type": "string" },
          "createdAt": { "type": "number" }
        },
        "required": ["groupId", "senderId", "text", "createdAt"]
      },
      "description": "Messages in group chats"
    }
  }
}
