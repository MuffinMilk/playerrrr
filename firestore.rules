rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          ((request.auth.token.email == "awdrej.puente@icloud.com" || request.auth.token.email == "awdrepuente408@gmail.com") && request.auth.token.email_verified == true));
    }
    function isBanned() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBanned == true;
    }
    function isTimedOut() {
      return isAuthenticated() && 
             ('timeoutUntil' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.timeoutUntil > request.time.toMillis();
    }
    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }
    function isValidUser() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['uid', 'displayName', 'photoURL', 'friendCode', 'currentSong', 'typingTo', 'role', 'createdAt', 'isBanned', 'timeoutUntil', 'warnings']) &&
             data.uid == request.auth.uid &&
             data.friendCode is string && data.friendCode.size() > 0 && data.friendCode.size() <= 20 &&
             (!('typingTo' in data) || data.typingTo is string) &&
             (!('role' in data) || data.role in ['user', 'admin']) &&
             (!('isBanned' in data) || data.isBanned is bool) &&
             (!('timeoutUntil' in data) || data.timeoutUntil is number) &&
             (!('warnings' in data) || data.warnings is list) &&
             (!('createdAt' in data) || data.createdAt is number);
    }
    function isValidFriendRequest() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['fromUid', 'fromName', 'fromPhoto', 'toUid', 'status', 'createdAt']) &&
             data.fromUid == request.auth.uid &&
             data.status == 'pending' &&
             data.createdAt is number;
    }
    function isValidFriendship() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['user1', 'user2', 'createdAt']) &&
             (data.user1 == request.auth.uid || data.user2 == request.auth.uid) &&
             data.createdAt is number;
    }
    function isValidPlaylist() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['userId', 'name', 'songs', 'isFavorites', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.name is string &&
             data.songs is list &&
             (data.isFavorites is bool || !('isFavorites' in data)) &&
             data.createdAt is number;
    }
    function isValidMessage() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['senderId', 'receiverId', 'text', 'createdAt']) &&
             data.senderId == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 1000 &&
             data.createdAt is number;
    }
    function isValidCall() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['callerId', 'receiverId', 'offer', 'answer', 'status', 'type', 'createdAt']) &&
             (data.callerId == request.auth.uid || data.receiverId == request.auth.uid) &&
             data.status in ['ringing', 'ongoing', 'ended'] &&
             data.type in ['voice', 'video'] &&
             data.createdAt is number;
    }
    function isValidCandidate() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['callId', 'senderId', 'candidate', 'createdAt']) &&
             data.senderId == request.auth.uid &&
             data.createdAt is number;
    }
    function isValidGroup() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['name', 'ownerId', 'members', 'createdAt']) &&
             data.ownerId == request.auth.uid &&
             data.members is list && data.members.size() >= 2 &&
             data.members.size() <= 20 &&
             data.createdAt is number;
    }
    function isValidGroupMessage() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['groupId', 'senderId', 'senderName', 'senderPhoto', 'senderRole', 'text', 'createdAt']) &&
             data.senderId == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 1000 &&
             data.createdAt is number;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && !isBanned() && isValidUser() && (!('role' in request.resource.data) || request.resource.data.role == 'user' || isAdmin());
      allow update: if (isOwner(userId) && !isBanned() && isValidUser() && 
                       (!('role' in request.resource.data) || request.resource.data.role == resource.data.role) &&
                       (!('isBanned' in request.resource.data) || request.resource.data.isBanned == resource.data.isBanned) &&
                       (!('timeoutUntil' in request.resource.data) || request.resource.data.timeoutUntil == resource.data.timeoutUntil) &&
                       (!('warnings' in request.resource.data) || request.resource.data.warnings == resource.data.warnings)) || 
                       isAdmin();
    }

    match /friendRequests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow create: if isAuthenticated() && isValidFriendRequest();
      allow delete: if isAuthenticated() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
    }

    match /friendships/{friendshipId} {
      allow read: if isAuthenticated() && (resource.data.user1 == request.auth.uid || resource.data.user2 == request.auth.uid);
      allow create: if isAuthenticated() && isValidFriendship();
      allow delete: if isAuthenticated() && (resource.data.user1 == request.auth.uid || resource.data.user2 == request.auth.uid);
    }

    match /playlists/{playlistId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidPlaylist();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidPlaylist();
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && !isBanned() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isAuthenticated() && !isBanned() && !isTimedOut() && isValidMessage();
    }

    match /calls/{callId} {
      allow read: if isAuthenticated() && (resource.data.callerId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isAuthenticated() && isValidCall();
      allow update: if isAuthenticated() && (resource.data.callerId == request.auth.uid || resource.data.receiverId == request.auth.uid) && isValidCall();
      allow delete: if isAuthenticated() && (resource.data.callerId == request.auth.uid || resource.data.receiverId == request.auth.uid);

      match /candidates/{candidateId} {
        allow read: if isAuthenticated() && (get(/databases/$(database)/documents/calls/$(callId)).data.callerId == request.auth.uid || get(/databases/$(database)/documents/calls/$(callId)).data.receiverId == request.auth.uid);
        allow create: if isAuthenticated() && isValidCandidate();
      }
    }

    match /groups/{groupId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.members;
      allow create: if isAuthenticated() && isValidGroup();
      allow update: if isAuthenticated() && request.auth.uid in resource.data.members && isValidGroup();
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    match /groupMessages/{messageId} {
      allow read: if isAuthenticated() && !isBanned() && request.auth.uid in get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.members;
      allow create: if isAuthenticated() && !isBanned() && !isTimedOut() && isValidGroupMessage() && request.auth.uid in get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.members;
    }

    match /announcements/{announcementId} {
      allow read: if isAuthenticated() && !isBanned();
      allow create, delete: if isAdmin();
    }
  }
}
